# Azure AI Foundry project endpoint
# Get this from: Foundry portal → Project → Overview → Project connection string
AZURE_AI_FOUNDRY_ENDPOINT=https://<your-project>.services.ai.azure.com

# Replace the <placeholder> values inside prior_auth_agent.py with the
# connection IDs of the AI Search and Logic App resources you created
# via the Foundry portal under Settings → Connected resources.
#
#   <your-search-connection-id>      → Azure AI Search connection
#   <your-logic-app-connection-id>   → Logic Apps connection
