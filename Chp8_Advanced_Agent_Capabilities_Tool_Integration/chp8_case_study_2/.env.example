# Azure AI Foundry project endpoint
# Get this from: Foundry portal → Project → Overview → Project connection string
AZURE_AI_FOUNDRY_ENDPOINT=https://<your-project>.services.ai.azure.com

# MCP server bearer tokens
# In production, source these from Azure Key Vault rather than environment
# variables. The placeholders inside helpdesk_agent.py headers must be
# replaced with the actual token values (or refactored to read from env).
#
#   <github-token>  → GitHub personal access token (repo read + issues write)
#   <devops-token>  → Azure DevOps personal access token (work items)
GITHUB_PAT=<your-github-personal-access-token>
AZURE_DEVOPS_PAT=<your-azure-devops-personal-access-token>

# Azure AI Search connection ID for the it-knowledge-base index
# Replace <search-connection-id> inside helpdesk_agent.py
